{
  "name": "outline-editor",
  "version": "0.1.0",
  "description": "Standalone Outline document editor with full editing UI (no realtime collaboration)",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "PUBLISH.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./dist/outline-editor.css"
  },
  "scripts": {
    "build": "vite build && cp ./src/public/index.d.ts ./dist/index.d.ts",
    "clean": "rm -rf dist",
    "verify:exports": "node ./scripts/verify-exports.cjs",
    "pack:dry": "npm_config_cache=/tmp/npm-cache npm pack --dry-run",
    "pack:local": "npm_config_cache=/tmp/npm-cache npm pack",
    "release:check": "npm run clean && npm run build && npm run verify:exports && npm run pack:dry",
    "prepack": "npm run clean && npm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "styled-components": ">=6"
  },
  "dependencies": {
    "@benrbray/prosemirror-math": "^1.0.0",
    "@emoji-mart/data": "^1.2.1",
    "@mermaid-js/layout-elk": "^0.1.4",
    "@radix-ui/react-toolbar": "^1.1.2",
    "@radix-ui/react-visually-hidden": "^1.1.0",
    "@sentry/react": "^8.20.0",
    "class-validator": "^0.14.2",
    "command-score": "^0.1.2",
    "copy-to-clipboard": "^3.3.3",
    "diff": "^5.1.0",
    "emoji-mart": "^5.6.0",
    "fuzzy-search": "^3.2.1",
    "i18next": "^25.4.2",
    "katex": "^0.16.11",
    "lodash": "^4.17.21",
    "markdown-it": "^14.1.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "mermaid": "^11.4.1",
    "mobx": "^6.13.7",
    "mobx-react": "^9.2.1",
    "outline-icons": "^1.91.0",
    "pako": "^2.1.0",
    "png-chunks-extract": "^1.0.0",
    "polished": "^4.3.1",
    "prosemirror-changeset": "^2.3.1",
    "prosemirror-codemark": "^0.4.2",
    "prosemirror-commands": "^1.6.2",
    "prosemirror-dropcursor": "^1.8.1",
    "prosemirror-gapcursor": "^1.3.2",
    "prosemirror-history": "^1.4.1",
    "prosemirror-inputrules": "^1.4.0",
    "prosemirror-keymap": "^1.2.2",
    "prosemirror-markdown": "^1.13.1",
    "prosemirror-model": "^1.24.1",
    "prosemirror-schema-list": "^1.5.0",
    "prosemirror-state": "^1.4.3",
    "prosemirror-tables": "^1.8.1",
    "prosemirror-transform": "^1.10.2",
    "prosemirror-view": "^1.41.0",
    "react-i18next": "^15.7.3",
    "react-portal": "^4.3.0",
    "react-router-dom": "^7.8.2",
    "react-use-measure": "^2.1.7",
    "refractor": "^4.9.0",
    "scroll-into-view-if-needed": "^3.1.0",
    "slugify": "^1.6.6",
    "sonner": "^1.4.41",
    "styled-components-breakpoint": "^3.0.0-preview.20",
    "utility-types": "^3.11.0",
    "uuid": "^11.0.2",
    "validator": "^13.12.0",
    "y-prosemirror": "^1.2.17",
    "yjs": "^13.6.27"
  },
  "devDependencies": {
    "@types/node": "^20.16.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-oxc": "^0.1.0",
    "typescript": "^5.5.4",
    "vite": "^6.2.6"
  }
}
